# Security
# Set a strong password here to protect your public dashboard
ACCESS_TOKEN=your_secure_password_here

# OpenAI/LLM Configuration
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://openai.com/api/
OPENAI_MODEL=gemini-2.5-flash

# Server Configuration
PORT=3000

# Jira Integration (Optional)
# Uncomment to enable Jira bug reporting
# JIRA_URL=https://your-jira-instance.atlassian.net
# JIRA_TOKEN=your_jira_token_here
# JIRA_PROJECT=PROJECT_KEY

# Slack Integration (Optional)
# Uncomment to enable Slack bug reporting
# SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
